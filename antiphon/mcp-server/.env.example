# Required: EOA private key for signing x402 payments and posting reputation
RACHAX402_PRIVATE_KEY=0x...

# Base Sepolia RPC (defaults to https://sepolia.base.org)
# BASE_RPC_URL=https://sepolia.base.org

# Storacha credentials for free CSV staging (copy from onchain-agent/.env)
STORACHA_AGENT_PRIVATE_KEY=MgCa...
STORACHA_AGENT_DELEGATION=mAYI...

# ERC-8004 contract addresses (defaults to deployed addresses)
# ERC8004_IDENTITY_REGISTRY=0x1352abA587fFbbC398d7ecAEA31e2948D3aFE4Fb
# ERC8004_REPUTATION_REGISTRY=0x3FdD300147940a35F32AdF6De36b3358DA682B5c
